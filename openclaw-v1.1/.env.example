# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# AI APIs
MISTRAL_API_KEY=your-mistral-key
ANTHROPIC_API_KEY=your-anthropic-key

# SAP Concur (OAuth2 refresh token flow)
CONCUR_CLIENT_ID=your-concur-app-client-id
CONCUR_CLIENT_SECRET=your-concur-app-client-secret
CONCUR_REFRESH_TOKEN=your-concur-refresh-token
CONCUR_COMPANY_ID=your-company-uuid

# Feishu / Lark
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret

# App Config
APP_ENV=development
LOG_LEVEL=INFO
MAX_WEEKLY_RULE_ADJUSTMENTS=3
LEARNING_MIN_FEEDBACK_COUNT=10
AB_TEST_MIN_SAMPLE=50
